    "def compute_sub_aqi(C, breakpoints):\n",
    "    \"\"\"\n",
    "    Piecewise linear interpolation:\n",
    "    AQI = ((AQI_high - AQI_low) / (C_high - C_low)) * (C - C_low) + AQI_low\n",
    "    Returns NaN if concentration is out of all breakpoint ranges.\n",
    "    \"\"\"\n",
    "    for (C_low, C_high, AQI_low, AQI_high) in breakpoints:\n",
    "        if C_low <= C <= C_high:\n",
    "            return ((AQI_high - AQI_low) / (C_high - C_low)) * (C - C_low) + AQI_low\n",
    "    return np.nan\n",
    "\n",
    "# EPA breakpoints — (C_low, C_high, AQI_low, AQI_high)\n",
    "BP_PM25 = [\n",
